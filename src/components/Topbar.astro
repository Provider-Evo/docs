---
import { site, topNav, searchIndex } from '../config/nav';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const pathname = Astro.url.pathname;
const searchJson = JSON.stringify(
  searchIndex.map((item) => ({
    text: item.text,
    href: `${base}${item.href.replace(/^\//, '')}`,
  }))
);
---

<header class="docs-topbar">
  <div class="docs-topbar-brand">
    <button type="button" class="docs-btn docs-sidebar-toggle" id="sidebar-toggle" aria-label="切换侧栏">菜单</button>
    <a href={base} class="docs-btn docs-home-shortcut" aria-label="返回文档首页">首页</a>
    <a href={base} class="docs-brand-link" aria-label="返回文档首页">
      <span class="docs-brand-mark" aria-hidden="true">P</span>
      <span class="docs-brand-text">{site.title}</span>
    </a>
    <span class="docs-topbar-badge">v{site.version}</span>
  </div>
  <nav class="docs-topbar-nav" aria-label="主导航">
    {
      topNav.map((item) => {
        const href = `${base}${item.href.replace(/^\//, '')}`;
        const active = item.href === '/'
          ? pathname === base || pathname === `${base}index.html`
          : pathname.includes(item.href.replace(/^\//, '').replace(/\/$/, ''));
        return (
          <a href={href} class:list={{ 'is-active': active }}>
            {item.text}
          </a>
        );
      })
    }
  </nav>
  <div class="docs-topbar-actions">
    <div class="docs-search" id="docs-search">
      <input type="search" placeholder="搜索文档…" autocomplete="off" id="docs-search-input" />
      <div class="docs-search-results" id="docs-search-results"></div>
    </div>
    <button type="button" class="docs-btn" id="theme-toggle" aria-label="切换主题">主题</button>
    <a class="docs-btn" href={site.github} target="_blank" rel="noopener">GitHub</a>
  </div>
</header>

<script define:vars={{ searchJson, base }}>
  window.__DOCS_SEARCH__ = JSON.parse(searchJson);
  window.__DOCS_BASE__ = base;
</script>
