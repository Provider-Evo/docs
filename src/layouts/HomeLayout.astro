---
import Base from './Base.astro';
import Topbar from '../components/Topbar.astro';
import { site, homeFeatures } from '../config/nav';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : `${rawBase}/`;
const link = (path: string) => `${base}${path.replace(/^\//, '')}`;
---

<Base title={`${site.title} 文档中心`} description={site.tagline}>
  <div class="docs-app">
    <Topbar />
    <div class="docs-home">
      <section class="docs-hero">
        <canvas class="docs-hero-canvas" id="hero-canvas" aria-hidden="true"></canvas>
        <div class="docs-hero-inner">
          <h1>{site.title}</h1>
          <p>{site.tagline}。插件化多平台 AI 网关，内置 WebUI 与市场。</p>
          <div class="docs-hero-actions">
            <a class="docs-btn docs-btn--primary" href={link('/manual/quickstart/')}>快速开始</a>
            <a class="docs-btn" href={link('/plugins/')}>插件系统</a>
            <a class="docs-btn" href={link('/develop/')}>开发文档</a>
          </div>
        </div>
      </section>
      <div class="docs-feature-grid">
        {
          homeFeatures.map((feature) => (
            <div class="ui-stat-card">
              <p class="ui-stat-card__label">{feature.title}</p>
              <p class="ui-stat-card__sub">{feature.details}</p>
            </div>
          ))
        }
      </div>
      <section class="docs-prose" style="margin-top: 40px">
        <h2>获取更多支持</h2>
        <ul>
          <li>
            <a href={site.github} target="_blank" rel="noopener">provider-core</a> 提交 Issue 或 PR
          </li>
          <li>
            <a href={site.pluginMarket} target="_blank" rel="noopener">plugin-repo</a> 插件市场索引
          </li>
          <li>
            <a href={link('/release/')}>发版历史</a>（dev {site.version}）
          </li>
        </ul>
      </section>
    </div>
  </div>
</Base>

<script>
  const canvas = document.getElementById('hero-canvas');
  if (canvas instanceof HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (ctx) {
      let width = 0;
      let height = 0;
      const particles = [];
      const resize = () => {
        width = canvas.width = canvas.offsetWidth;
        height = canvas.height = canvas.offsetHeight;
      };
      resize();
      window.addEventListener('resize', resize);
      for (let i = 0; i < 36; i += 1) {
        particles.push({
          x: Math.random() * width,
          y: Math.random() * height,
          r: Math.random() * 2 + 1,
          vx: (Math.random() - 0.5) * 0.4,
          vy: (Math.random() - 0.5) * 0.4,
        });
      }
      const tick = () => {
        ctx.clearRect(0, 0, width, height);
        const accent = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#4263eb';
        for (const p of particles) {
          p.x += p.vx;
          p.y += p.vy;
          if (p.x < 0 || p.x > width) p.vx *= -1;
          if (p.y < 0 || p.y > height) p.vy *= -1;
          ctx.beginPath();
          ctx.fillStyle = accent;
          ctx.globalAlpha = 0.35;
          ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
          ctx.fill();
        }
        ctx.globalAlpha = 1;
        requestAnimationFrame(tick);
      };
      tick();
    }
  }
</script>
