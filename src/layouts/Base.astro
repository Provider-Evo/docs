---
import '../styles/tokens.css';
import '../styles/shell.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Provider-Evo', description = 'Provider-Evo 官方文档' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script src={`${import.meta.env.BASE_URL}docs.js`} defer></script>
  </body>
</html>
